# Supabase (https://supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini — AI blog ve konu üretimi (aistudio.google.com/apikey)
# gemini-2.0-flash kapatıldı; gemini-2.5-flash veya gemini-2.5-flash-lite kullanın
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
# Cron başına üretilecek yazı sayısı (ücretsiz kota: 1 önerilir)
GEMINI_POSTS_PER_CRON=1

# Pexels — ücretsiz stok görseller (https://www.pexels.com/api/)
# Opsiyonel; yoksa yedek görsel havuzu kullanılır
PEXELS_API_KEY=your-pexels-api-key

# Admin CMS giriş şifresi
ADMIN_PASSWORD=guclu-bir-sifre-buraya

# JWT imzalama (üretimde ADMIN_PASSWORD'dan farklı, min 32 karakter önerilir)
ADMIN_SECRET=uzun-rastgele-bir-secret-anahtar-buraya

# Vercel Cron güvenliği (Vercel otomatik ekler, manuel test için)
CRON_SECRET=vercel-cron-secret
