# Neon Postgres (Vercel Marketplace → Storage → Neon)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Admin CMS giriş şifresi
ADMIN_PASSWORD=guclu-bir-sifre-buraya

# JWT imzalama (üretimde ADMIN_PASSWORD'dan farklı, min 32 karakter önerilir)
ADMIN_SECRET=uzun-rastgele-bir-secret-anahtar-buraya

# OpenAI — AI blog yazısı üretimi için
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Vercel Cron güvenliği (Vercel otomatik ekler, manuel test için)
CRON_SECRET=vercel-cron-secret
